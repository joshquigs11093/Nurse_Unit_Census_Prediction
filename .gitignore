# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
.pytest_cache/
*.egg-info/

# Jupyter
.ipynb_checkpoints/

# Environment
.env
.env.local

# Data — user-supplied; never tracked
data/raw/*
data/processed/*
data/external/*
!data/raw/.gitkeep
!data/processed/.gitkeep

# Build artifacts
/models/
/outputs/figures/*
/outputs/reports/
!/outputs/figures/dashboards/

# Notebooks (development; not part of deployed application)
/notebooks/

# Documentation — ignore everything not already tracked
docs/*

# Node / build tooling
node_modules/
/package.json
/package-lock.json
scripts/*

# Cache
.cache/

# IDE
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
